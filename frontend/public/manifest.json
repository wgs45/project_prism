{
  "manifest_version": 3,
  "name": "Prism Smart Summarizer",
  "version": "1.0.0",
  "description": "AI-powered contextual webpage summarizer.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
